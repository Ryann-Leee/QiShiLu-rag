# Qwen3-Embedding-0.6B CPU Docker 镜像
# 支持 Apple Silicon (M1/M2/M3) 和 Intel Mac

FROM --platform=linux/amd64 python:3.10-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 设置 HF Mirror
ENV HF_ENDPOINT=https://hf-mirror.com
ENV PYTHONUNBUFFERED=1

# 复制依赖文件
COPY requirements-embedding.txt .

# 安装 Python 依赖 (CPU 版本，支持 Apple Silicon)
RUN pip install --no-cache-dir torch torchvision torchaudio && \
    pip install --no-cache-dir transformers accelerate sentence-transformers fastapi uvicorn

# 复制服务代码
COPY *.py .

# 创建模型目录
RUN mkdir -p /app/models

# 暴露端口
EXPOSE 5001

# 启动命令
CMD ["python", "embedding_service.py", "--port", "5001", "--host", "0.0.0.0"]
