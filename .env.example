# =============================================================================
# Enterprise RAG System - Environment Configuration Template
# =============================================================================
# 复制此文件为 .env 并填入实际配置值
# =============================================================================

# -----------------------------------------------------------------------------
# 1. LLM (Large Language Model) Configuration
# 大语言模型配置 - 用于对话生成、文本补全等
# 支持: openai, azure-openai, anthropic, deepseek, kimi, doubao 等
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# 2. Embedding Model Configuration
# 文本嵌入模型配置 - 用于将文本转为向量
# 推荐: text-embedding-3-small (1536维), text-embedding-3-large (3072维)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=${LLM_API_KEY}
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------------
# 3. Milvus Vector Database Configuration
# 向量数据库配置 - 用于存储和检索文档向量
# 支持: Milvus Lite (本地), Milvus Cloud (云端), Zilliz Cloud
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=default
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_TIMEOUT=5000
MILVUS_EMBEDDING_DIMENSION=${EMBEDDING_DIMENSION}

# Zilliz Cloud 配置（云端 Milvus）
# MILVUS_CLOUD_ENDPOINT=https://xxx.zillizcloud.com:443
# MILVUS_CLOUD_TOKEN=your_zilliz_token

# -----------------------------------------------------------------------------
# 4. MySQL Database Configuration
# MySQL 数据库配置 - 用于存储分片元数据、会话等
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rag_db
DB_USERNAME=rag_user
DB_PASSWORD=your_mysql_password

# -----------------------------------------------------------------------------
# 5. Redis Configuration
# Redis 配置 - 用于会话记忆缓存、分布式锁等
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=3000

# -----------------------------------------------------------------------------
# 6. Application Server Configuration
# 应用服务器配置
# -----------------------------------------------------------------------------
SERVER_PORT=5000
SPRING_PROFILES_ACTIVE=default

# CORS 配置（生产环境建议限制具体域名）
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# -----------------------------------------------------------------------------
# 7. Multi-tenant Configuration
# 多租户隔离配置
# 隔离级别: METADATA (默认), PARTITION, COLLECTION
# -----------------------------------------------------------------------------
TENANT_DEFAULT_ISOLATION_LEVEL=METADATA
TENANT_ENABLE_PARTITION_ISOLATION=true
TENANT_ENABLE_COLLECTION_ISOLATION=false

# -----------------------------------------------------------------------------
# 8. Memory Configuration
# 记忆系统配置
# -----------------------------------------------------------------------------
# 会话记忆配置
MEMORY_SESSION_MAX_MESSAGES=20
MEMORY_SESSION_TTL_MINUTES=30

# 情景记忆配置
MEMORY_EPISODIC_TOP_K=5
MEMORY_EPISODIC_IMPORTANCE_THRESHOLD=0.3

# 用户画像配置
MEMORY_PROFILE_UPDATE_FREQUENCY=5

# -----------------------------------------------------------------------------
# 9. Text Processing Configuration
# 文本处理配置
# -----------------------------------------------------------------------------
SPLITTER_CHUNK_SIZE=500
SPLITTER_OVERLAP_TOKENS=100
SPLITTER_MIN_CHUNK_SIZE=50
TOKEN_ENCODING=cl100k_base

# -----------------------------------------------------------------------------
# 10. Security Configuration
# 安全配置
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_random_secret_in_production
JWT_EXPIRATION=86400000
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# 11. Logging Configuration
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_MILVUS=INFO

# -----------------------------------------------------------------------------
# 12. Environment Mode
# 环境模式
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG_MODE=false
