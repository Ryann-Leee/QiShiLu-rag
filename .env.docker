# =============================================================================
# Enterprise RAG System - Docker 环境完整配置
# =============================================================================
# 使用方法: cp .env.docker .env && docker-compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# 1. LLM (Large Language Model) Configuration
# 大语言模型配置 - 支持: glm, openai, deepseek, kimi, doubao 等
# -----------------------------------------------------------------------------
LLM_PROVIDER=glm
LLM_MODEL=glm-4.5-air
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# 2. Embedding Model Configuration
# 文本嵌入模型配置 - 本地模型或 OpenAI API
# -----------------------------------------------------------------------------
# 方式一: 本地 Qwen3-Embedding (Docker Embedding 服务)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Qwen3-Embedding-0.6B
EMBEDDING_LOCAL_URL=http://localhost:5001
EMBEDDING_DIMENSION=1024

# 方式二: OpenAI API (注释掉上面，使用下面配置)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=${LLM_API_KEY}
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------------
# 3. Milvus Vector Database Configuration (v2.5+)
# Docker 环境使用 milvus-standalone 服务名
# -----------------------------------------------------------------------------
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_DATABASE=default
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_TIMEOUT=10000
MILVUS_EMBEDDING_DIMENSION=${EMBEDDING_DIMENSION}
MILVUS_COLLECTION_NAME=knowledge_base

# Milvus 服务端口映射 (docker-compose 端口)
MILVUS_HOST_PORT=19530
MILVUS_MONITOR_PORT=9091

# Milvus 数据存储路径
MILVUS_DATA_DIR=./milvus_data
MILVUS_CONFIG_DIR=./milvus_config

# Zilliz Cloud 配置 (可选，取消下面注释使用云端)
# MILVUS_HOST=your-cluster.zillizcloud.com
# MILVUS_PORT=443
# MILVUS_CLOUD_ENDPOINT=https://your-cluster.zillizcloud.com:443
# MILVUS_CLOUD_TOKEN=your_zilliz_token

# -----------------------------------------------------------------------------
# 3.1 Hybrid Search Configuration (RRF)
# 双路混合检索配置 - Milvus 2.5+ 稠密向量 + BM25 融合
# -----------------------------------------------------------------------------
# 稠密向量召回数量 (语义搜索)
HYBRID_SEARCH_DENSE_TOP_K=100

# 稀疏向量召回数量 (关键词搜索)
HYBRID_SEARCH_SPARSE_TOP_K=100

# RRF 融合常数 K (推荐值: 40-60)
HYBRID_SEARCH_RRF_K=60

# 最终返回结果数量
HYBRID_SEARCH_FINAL_TOP_K=10

# -----------------------------------------------------------------------------
# 4. MySQL Database Configuration
# Docker 环境使用 mysql 服务名
# -----------------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=rag_db
DB_USERNAME=rag_user
DB_PASSWORD=rag_password

# Docker 端口映射 (本地开发使用)
DB_HOST_PORT=3306

# MySQL 连接池配置
# DB_POOL_SIZE=10
# DB_MAX_LIFETIME=1800000

# -----------------------------------------------------------------------------
# 5. Redis Configuration
# Docker 环境使用 redis 服务名
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=3000

# Docker 端口映射 (本地开发使用)
REDIS_HOST_PORT=6379

# Redis 连接池配置
# REDIS_POOL_MAX_TOTAL=8
# REDIS_POOL_MAX_IDLE=8
# REDIS_POOL_MIN_IDLE=0

# -----------------------------------------------------------------------------
# 6. MinIO Object Storage Configuration
# Milvus 依赖的对象存储
# -----------------------------------------------------------------------------
MINIO_HOST_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# 7. Application Server Configuration
# 应用服务器配置
# -----------------------------------------------------------------------------
SERVER_PORT=5000
SPRING_PROFILES_ACTIVE=default

# CORS 配置
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# -----------------------------------------------------------------------------
# 8. Multi-tenant Configuration
# 多租户隔离配置
# 隔离级别: METADATA (默认), PARTITION, COLLECTION
# -----------------------------------------------------------------------------
TENANT_DEFAULT_ISOLATION_LEVEL=METADATA
TENANT_ENABLE_PARTITION_ISOLATION=true
TENANT_ENABLE_COLLECTION_ISOLATION=false

# -----------------------------------------------------------------------------
# 9. Memory Configuration
# 记忆系统配置
# -----------------------------------------------------------------------------
# 会话记忆配置
MEMORY_SESSION_MAX_MESSAGES=20
MEMORY_SESSION_TTL_MINUTES=30

# 情景记忆配置
MEMORY_EPISODIC_TOP_K=5
MEMORY_EPISODIC_IMPORTANCE_THRESHOLD=0.3

# 用户画像配置
MEMORY_PROFILE_UPDATE_FREQUENCY=5

# -----------------------------------------------------------------------------
# 10. Text Processing Configuration
# 文本处理配置
# -----------------------------------------------------------------------------
# 分片配置
SPLITTER_CHUNK_SIZE=500
SPLITTER_OVERLAP_TOKENS=100
SPLITTER_MIN_CHUNK_SIZE=50

# Token 计数编码
TOKEN_ENCODING=cl100k_base

# -----------------------------------------------------------------------------
# 11. Security Configuration
# 安全配置
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_random_secret_in_production
JWT_EXPIRATION=86400000
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# 12. Logging Configuration
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_MILVUS=INFO

# -----------------------------------------------------------------------------
# 13. Environment Mode
# 环境模式
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG_MODE=false
